# Nebula Sync Configuration
PRIMARY=http://10.100.0.11|{{ pihole_web_password }}
REPLICAS=http://10.100.0.10|{{ pihole_web_password }}
TZ={{ timezone }}
FULL_SYNC=true
RUN_GRAVITY=true

# Discord Webhook Configuration
WEBHOOK_SYNC_SUCCESS_URL={{ discord_webhook_url }}
WEBHOOK_SYNC_FAILURE_URL={{ discord_webhook_url }}
WEBHOOK_SYNC_SUCCESS_METHOD=POST
WEBHOOK_SYNC_FAILURE_METHOD=POST
WEBHOOK_SYNC_SUCCESS_BODY=🟢 Nebula Sync daily check completed successfully
WEBHOOK_SYNC_FAILURE_BODY=🔴 Nebula Sync daily check failed
WEBHOOK_SYNC_SUCCESS_HEADERS=Content-Type:application/json
WEBHOOK_SYNC_FAILURE_HEADERS=Content-Type:application/json